# Twilio Settings (required for SMS delivery)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Settings (required for AI responses)
OPENAI_API_KEY=your_openai_api_key

# Frontend Settings (optional; defaults to the local backend if omitted)
VITE_API_BASE_URL=http://localhost:8000

# Vapi Frontend Settings (only needed if you re-enable the Vapi web SDK)
VITE_VAPI_ASSISTANT_ID=5ea8431d-8521-4644-b002-2285095a8def
VITE_VAPI_PUBLIC_KEY=17cea840-20a9-4a84-a536-2f28d1e31f02

# Qdrant Settings (optional; keep empty for in-memory)
# QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# Vapi Settings (optional)
# VAPI_SECRET=your_vapi_secret for validating webhook payloads
